<?xml version="1.0" encoding="utf-8"?>
<Sysmon schemaversion="4.90">
  <!--
    Sysmon ":contentReference[oaicite:2]{index=2} (schema 4.90 / Sysmon v15.x)
    Behavior:
      - All filterable event types are present and configured to log nothing.
      - Note: Event ID 4 (service state change) and Event ID 16 (config change) are not filterable.
  -->

  <!-- Global configuration entries -->
  <HashAlgorithms>*</HashAlgorithms>
  <CheckRevocation>True</CheckRevocation>
  <DnsLookup>False</DnsLookup>

  <!-- ArchiveDirectory is the folder name under the root of each volume (e.g., C:\Sysmon\) -->
  <ArchiveDirectory>Sysmon</ArchiveDirectory>

  <!-- Driver/service image name (commonly limited; keep simple) -->
  <DriverName>SysmonDrv</DriverName>

  <!-- Clipboard monitoring toggle (Event ID 24). Even if enabled, we still filter it out below. -->
  <CaptureClipboard>False</CaptureClipboard>

  <!-- Limit noisy/huge fields (format: Field:Size,Field:Size,...) -->
  <FieldSizes>CommandLine:4096,ParentCommandLine:4096,Image:260,ParentImage:260,CurrentDirectory:260,TargetFilename:520,ImageLoaded:520,DestinationHostname:255,SourceHostname:255</FieldSizes>

</Sysmon>