<?xml version="1.0" encoding="utf-8"?>
<Sysmon schemaversion="4.90">
  <!--
    Sysmon ":contentReference[oaicite:2]{index=2} (schema 4.90 / Sysmon v15.x)
    Behavior:
      - All filterable event types are present and configured to log nothing.
      - Note: Event ID 4 (service state change) and Event ID 16 (config change) are not filterable.
  -->

  <!-- Global configuration entries -->
  <HashAlgorithms>*</HashAlgorithms>
  <CheckRevocation>True</CheckRevocation>
  <DnsLookup>True</DnsLookup>

  <!-- ArchiveDirectory is the folder name under the root of each volume (e.g., C:\Sysmon\) -->
  <ArchiveDirectory>Sysmon</ArchiveDirectory>

  <!-- Driver/service image name (commonly limited; keep simple) -->
  <DriverName>SysmonDrv</DriverName>

  <!-- Clipboard monitoring toggle (Event ID 24). Even if enabled, we still filter it out below. -->
  <CaptureClipboard>False</CaptureClipboard>

  <!-- Limit noisy/huge fields (format: Field:Size,Field:Size,...) -->
  <FieldSizes>CommandLine:4096,ParentCommandLine:4096,Image:260,ParentImage:260,CurrentDirectory:260,TargetFilename:520,ImageLoaded:520,DestinationHostname:255,SourceHostname:255</FieldSizes>

  <EventFiltering>
    <!-- Event ID 1 -->
    <ProcessCreate onmatch="include" />

    <!-- Event ID 2 -->
    <FileCreateTime onmatch="include" />

    <!-- Event ID 3 -->
    <NetworkConnect onmatch="include" />
	
	<!-- Event ID 4 -->
    <DriverLoad onmatch="include" />

    <!-- Event ID 5 -->
    <ProcessTerminate onmatch="include" />

    <!-- Event ID 6 -->
    <DriverLoad onmatch="include" />

    <!-- Event ID 7 -->
    <ImageLoad onmatch="include" />

    <!-- Event ID 8 -->
    <CreateRemoteThread onmatch="include" />

    <!-- Event ID 9 -->
    <RawAccessRead onmatch="include" />

    <!-- Event ID 10 -->
    <ProcessAccess onmatch="include" />

    <!-- Event ID 11 -->
    <FileCreate onmatch="include" />

    <!-- Event IDs 12–14 -->
    <RegistryEvent onmatch="include" />

    <!-- Event ID 15 -->
    <FileCreateStreamHash onmatch="include" />

    <!-- Event IDs 17–18 -->
    <PipeEvent onmatch="include" />

    <!-- Event IDs 19–21 -->
    <WmiEvent onmatch="include" />

    <!-- Event ID 22 -->
    <DnsQuery onmatch="include" />

    <!-- Event ID 23 -->
    <FileDelete onmatch="include" />

    <!-- Event ID 24
    <ClipboardChange onmatch="include" /> -->

    <!-- Event ID 25 -->
    <ProcessTampering onmatch="include" />

    <!-- Event ID 26
    <FileDeleteDetected onmatch="include" /> -->

    <!-- Event ID 27
    <FileBlockExecutable onmatch="include" /> -->

    <!-- Event ID 28
    <FileBlockShredding onmatch="include" /> -->

    <!-- Event ID 29
    <FileExecutableDetected onmatch="include" /> -->
  </EventFiltering>
</Sysmon>